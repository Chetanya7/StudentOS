# Server
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000

# Google auth.
# Use the Web OAuth client ID if the frontend sends Google ID tokens.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Optional hackathon bypass. Keep false for demos with real login.
ALLOW_DEV_AUTH=false

# Hugging Face router
HF_TOKEN=hf_your_token_here
HF_MODEL_URL=Qwen/Qwen2.5-7B-Instruct-Turbo
HF_VISION_MODEL_URL=Qwen/Qwen3.5-9B
HF_ROUTER_URL=https://router.huggingface.co/v1/chat/completions
